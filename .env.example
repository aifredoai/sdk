# ── REQUIRED ──────────────────────────────────────────────────────────────
# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your domain (where Fred will be accessible)
FRED_DOMAIN=fred.yourdomain.com

# ── FRED IDENTITY ─────────────────────────────────────────────────────────
# Customise Fred for your business
FRED_AGENT_NAME=Fred
FRED_BUSINESS_NAME=Your Company Name
FRED_BUSINESS_DESCRIPTION=We help businesses with...

# ── EMAIL / OUTREACH ──────────────────────────────────────────────────────
# Optional: Resend API key for outbound email (resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=fred@yourdomain.com
FROM_NAME=Fred

# ── SEARCH ────────────────────────────────────────────────────────────────
# Optional: Tavily API key for web research (tavily.com)
TAVILY_API_KEY=tvly-...

# ── GOOGLE WORKSPACE ──────────────────────────────────────────────────────
# OAuth credentials from console.cloud.google.com
# Follow setup guide: https://aifredoai.github.io/sdk/google-setup
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── INTERNAL ──────────────────────────────────────────────────────────────
# Auto-generated on first run — do not change
FRED_LICENSE_KEY=
